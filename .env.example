# ─── Supabase: públicas (seguras en el cliente) ───────────────────────────
# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Supabase → Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Supabase: SECRETA (solo servidor / scripts / Edge Functions) ─────────
# Supabase → Project Settings → API → Project API keys → service_role secret
# ⚠️ NUNCA prefijar con NEXT_PUBLIC_ ni usar en código de cliente.
SUPABASE_SERVICE_ROLE_KEY=
